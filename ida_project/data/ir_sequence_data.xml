<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Yearly-reset project sequence.

            use_date_range=True causes Odoo to maintain a separate
            ir.sequence.date_range per calendar year, each starting at 1.
            The sequence therefore returns 001, 002 … 999 within any given
            year and resets automatically on 1 January.

            The year, department code, and location suffix are prepended /
            appended by ida_project.sale_order._generate_base_project_number()
            to form the full number:  {YEAR}-{DEPT_CODE}-{SEQ}-{LOC_SEQ}
        -->
        <record id="seq_ida_project_number" model="ir.sequence">
            <field name="name">IDA Project Number</field>
            <field name="code">ida.project.number</field>
            <field name="prefix"></field>
            <field name="suffix"></field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
