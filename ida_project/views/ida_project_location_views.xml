<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_ida_project_location_list" model="ir.ui.view">
        <field name="name">ida.project.location.list</field>
        <field name="model">ida.project.location</field>
        <field name="arch" type="xml">
            <list string="Project Locations">
                <field name="code"/>
                <field name="name"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_ida_project_location_form" model="ir.ui.view">
        <field name="name">ida.project.location.form</field>
        <field name="model">ida.project.location</field>
        <field name="arch" type="xml">
            <form string="Project Location">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ida_project_location" model="ir.actions.act_window">
        <field name="name">Project Locations</field>
        <field name="res_model">ida.project.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu: Project → Configuration → Project Locations -->
    <menuitem
        id="menu_ida_project_location"
        name="Project Locations"
        parent="project.menu_project_config"
        action="action_ida_project_location"
        sequence="20"/>

</odoo>
