<?xml version="1.0" encoding="utf-8"?>
<templates>
    <!--
        Extends analytic.AnalyticDistributionPopup (the popup table template
        called via t-call from AnalyticDistribution) to add an "Amount" column.

        XPath strategy:
          - Header : insert <th> BEFORE the delete-column <th class="deleteColumn w-20px"/>
          - Data rows: insert <td> BEFORE the delete-button <td class="w-20px"/>

        The amount is computed by idaGetAnalyticAmount() patched onto
        AnalyticDistribution, which owns the t-call — so 'this' is available
        throughout the popup template including inside Record slot content.
        Percentage is read from data.record.data.percentage (the virtual record
        created per distribution line inside the Record component).
    -->
    <t t-inherit="analytic.AnalyticDistributionPopup" t-inherit-mode="extension">

        <!-- 1. Amount column header — before the delete placeholder header -->
        <xpath expr="//th[hasclass('deleteColumn')]" position="before">
            <th class="o_ida_analytic_amount numeric_column_width text-end">Amount</th>
        </xpath>

        <!-- 2. Amount cell per row — before the delete icon cell -->
        <xpath expr="//td[hasclass('w-20px')]" position="before">
            <td class="o_ida_analytic_amount numeric_column_width text-end">
                <t t-esc="idaGetAnalyticAmount(data.record.data.percentage)"/>
            </td>
        </xpath>

    </t>
</templates>
